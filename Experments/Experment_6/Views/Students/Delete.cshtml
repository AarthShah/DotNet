@model Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="card shadow-sm border-0 page-card">
    <div class="card-body p-4">
        <h1 class="h3 mb-3">Delete Student</h1>
        <p class="text-muted">This page demonstrates the Delete part of CRUD.</p>

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">@Model.Age</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-danger">Delete Student</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
